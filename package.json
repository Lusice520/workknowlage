{
  "name": "workknowlage",
  "private": true,
  "version": "0.1.0",
  "productName": "WorkKnowlage",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k -n RENDERER,APP -c cyan,green \"npm:dev:renderer\" \"npm:dev:app\"",
    "dev:renderer": "vite --host 127.0.0.1 --port 5175 --strictPort",
    "dev:app": "wait-on tcp:5175 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5175 nodemon --watch electron --ext cjs,js,mjs --exec \"electron electron/main.cjs\"",
    "build": "vite build",
    "icon:build": "node scripts/generate-icon-assets.mjs",
    "package:mac:dir": "npm run build && npm run icon:build && electron-builder --mac --dir",
    "package:mac": "npm run build && npm run icon:build && electron-builder --mac dmg",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.node.json --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "lucide-react": "^0.575.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@blocknote/core": "^0.47.3",
    "@blocknote/mantine": "^0.47.3",
    "@blocknote/react": "^0.47.3",
    "@mantine/core": "^8.3.18",
    "@mantine/hooks": "^8.3.18",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.1.13",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@tiptap/core": "^3.20.5",
    "@tiptap/extension-code": "^3.20.5",
    "@tiptap/extension-table": "^3.20.5",
    "@tiptap/extension-table-cell": "^3.20.5",
    "@tiptap/extension-table-header": "^3.20.5",
    "@tiptap/extension-table-row": "^3.20.5",
    "@tiptap/extension-underline": "^3.20.5",
    "@tiptap/pm": "^3.20.5",
    "@tiptap/react": "^3.20.5",
    "@tiptap/starter-kit": "^3.20.5",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.5.2",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.0.0",
    "docx": "^9.6.1",
    "electron": "^37.7.1",
    "electron-builder": "^26.8.1",
    "jsdom": "^26.1.0",
    "linkifyjs": "^4.3.2",
    "nodemon": "^3.1.10",
    "prosemirror-docx": "^0.6.1",
    "prosemirror-tables": "^1.8.5",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.2",
    "vite": "^7.1.5",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.workknowlage.desktop",
    "productName": "WorkKnowlage",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "package.json",
      "!src/**/*",
      "!docs/**/*",
      "!scripts/**/*",
      "!release/**/*",
      "!build/icon/*.iconset{,/**}"
    ],
    "asarUnpack": [
      "**/*.node"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon/WorkKnowlage.icns",
      "target": [
        "dmg"
      ],
      "artifactName": "WorkKnowlage-${version}-${arch}.${ext}"
    },
    "dmg": {
      "artifactName": "WorkKnowlage-${version}-${arch}.${ext}",
      "writeUpdateInfo": false
    }
  }
}
